#############################################
# START/STOP/RESTART
#############################################
cmd_start_internal() {
    local AIRCRAFT_IP="$1"
    echo "[*] Starting GCS services..."
    start_local_services
    [ -n "$AIRCRAFT_IP" ] && { echo "[*] Starting Aircraft services..."; start_aircraft_services "$AIRCRAFT_IP"; }
    echo "[*] Services started."
}

cmd_start() { cmd_start_internal "$(require_aircraft_ip "$1")"; }

cmd_stop_internal() {
    local AIRCRAFT_IP="$1"
    stop_local_services
    [ -n "$AIRCRAFT_IP" ] && stop_aircraft_services "$AIRCRAFT_IP"
}

cmd_stop() { cmd_stop_internal "$(get_aircraft_ip "$1")"; }

cmd_restart() {
    local AIRCRAFT_IP=$(require_aircraft_ip "$1")
    cmd_stop_internal "$AIRCRAFT_IP"
    sleep $SERVICE_RESTART_DELAY
    cmd_start_internal "$AIRCRAFT_IP"
    echo "[*] Waiting for STP (45s)..."
    sleep 45
    cmd_status
}

#############################################
# STATUS
#############################################
cmd_status() {
    local GCS_IP=$(get_tailscale_ip_nowait)
    
    echo "========================================="
    echo "  L2 Bridge Status"
    echo "========================================="
    echo ""
    echo "[Tailscale] ${GCS_IP:-NOT READY}"
    echo ""
    echo "[Processes]"
    pgrep -f kcptun-server >/dev/null && echo "  kcptun-server: RUNNING" || echo "  kcptun-server: STOPPED"
    pgrep tincd >/dev/null && echo "  tincd:         RUNNING" || echo "  tincd:         STOPPED"
    echo ""
    echo "[Interface]"
    if ip link show l2bridge >/dev/null 2>&1; then
        echo "  l2bridge: UP (MTU: $(ip link show l2bridge | grep -o 'mtu [0-9]*' | cut -d' ' -f2))"
    else
        echo "  l2bridge: NOT FOUND"
    fi
    echo ""
    echo "[Tinc Peers]"
    tinc -n l2bridge dump nodes 2>/dev/null || echo "  Not running"
    echo ""
    echo "[Watchdog]"
    crontab -l 2>/dev/null | grep -q "l2bridge-watchdog" && echo "  Status: ACTIVE" || echo "  Status: INACTIVE"
    [ -f "$HEALTH_FILE" ] && { . "$HEALTH_FILE"; echo "  Last: $STATUS ($LAST_CHECK)"; }
    echo ""
    [ -f "$STATE_FILE" ] && { . "$STATE_FILE"; [ -n "$AIRCRAFT_IP" ] && echo "[Aircraft] $AIRCRAFT_IP"; }
}

cmd_remote() {
    local AIRCRAFT_IP=$(require_aircraft_ip "$1")
    check_aircraft_reachable "$AIRCRAFT_IP" || { echo "Aircraft unreachable"; exit 1; }
    ssh_aircraft "$AIRCRAFT_IP" '
        echo "=== Aircraft Status ==="
        pgrep -f kcptun-client >/dev/null && echo "kcptun-client: RUNNING" || echo "kcptun-client: STOPPED"
        pgrep tincd >/dev/null && echo "tincd: RUNNING" || echo "tincd: STOPPED"
        ip link show l2bridge 2>/dev/null && echo "l2bridge: UP" || echo "l2bridge: DOWN"
        tinc -n l2bridge dump nodes 2>/dev/null
    '
}

cmd_logs() { logread 2>/dev/null | grep -iE "tinc|kcptun|l2bridge" | tail -"${1:-20}"; }

cmd_debug() {
    local AIRCRAFT_IP=$(require_aircraft_ip "$1")
    cmd_status
    echo "=== Logs ===" && cmd_logs 10
    echo "=== Watchdog Log ===" && tail -10 /tmp/l2bridge-watchdog.log 2>/dev/null || echo "None"
    check_aircraft_reachable "$AIRCRAFT_IP" && { echo "=== Aircraft ===" && cmd_remote "$AIRCRAFT_IP"; }
}

cmd_config() {
    echo "GCS IP:      $(get_tailscale_ip_nowait)"
    echo "KCP Port:    $KCPTUN_PORT"
    echo "Bridge MTU:  $BRIDGE_MTU"
    echo "KCP MTU:     $KCP_SEGMENT_MTU"
    [ -f "$STATE_FILE" ] && { . "$STATE_FILE"; echo "Aircraft:    $AIRCRAFT_IP"; }
}

cmd_uninstall() {
    local AIRCRAFT_IP=$(get_aircraft_ip "$1")
    printf "Remove all config? [y/N] "; read confirm
    [ "$confirm" != "y" ] && [ "$confirm" != "Y" ] && exit 0
    cmd_watchdog_remove 2>/dev/null || true
    cmd_stop_internal "$AIRCRAFT_IP" 2>/dev/null || true
    /etc/init.d/kcptun-server disable 2>/dev/null || true
    /etc/init.d/tinc-l2bridge disable 2>/dev/null || true
    rm -rf /etc/tinc/$NETWORK_NAME /etc/kcptun/server.json /etc/init.d/kcptun-server /etc/init.d/tinc-l2bridge "$STATE_FILE" "$HEALTH_FILE"
    [ -n "$AIRCRAFT_IP" ] && check_aircraft_reachable "$AIRCRAFT_IP" && ssh_aircraft "$AIRCRAFT_IP" '
        /etc/init.d/kcptun-client disable 2>/dev/null || true
        /etc/init.d/tinc-l2bridge disable 2>/dev/null || true
        rm -rf /etc/tinc/l2bridge /etc/kcptun/client.json /etc/init.d/kcptun-client /etc/init.d/tinc-l2bridge
