#!/bin/sh
#
# Kuruka RVR L2 Bridge Tool v2.2
# Manages L2 bridge between GCS and Aircraft over Tailscale
# Supports full 1500 MTU for device compatibility (cameras, etc.)
# Includes robust auto-reconnection and health monitoring
#
# Usage: l2bridge <command> [options]
#

set -e

#############################################
# LOGGING
#############################################
SETUP_LOG="/tmp/l2bridge-setup.log"

# Initialize log file for setup commands
init_setup_log() {
    exec > >(tee -a "$SETUP_LOG") 2>&1
    echo ""
    echo "========================================="
    echo "  L2Bridge Setup Log - $(date)"
    echo "========================================="
}

# Log a command and its output (for debugging)
log_cmd() {
    local desc="$1"
    shift
    echo "[CMD] $desc: $*"
    "$@" 2>&1 || echo "[CMD] Command failed with exit code: $?"
}

#############################################
# CONFIGURATION
#############################################
KCPTUN_PORT="4000"
KCPTUN_LOCAL_PORT="4001"
TINC_PORT="655"
KCPTUN_KEY="KurukaRVRL2BridgeKey2024"
NETWORK_NAME="l2bridge"

# MTU Configuration
BRIDGE_MTU="1500"
KCP_SEGMENT_MTU="1200"
KCP_STREAMBUF="4194304"

# Timing configuration
TAILSCALE_WAIT_TIMEOUT=120
TAILSCALE_CHECK_INTERVAL=5
KCPTUN_SETTLE_TIME=3
SERVICE_RESTART_DELAY=5
HEALTH_CHECK_INTERVAL=30

STATE_FILE="/etc/l2bridge.conf"
HEALTH_FILE="/tmp/l2bridge.health"
SSH_KEY="/root/.ssh/id_dropbear"
SSH_PUBKEY="/root/.ssh/id_dropbear.pub"

#############################################
# HELPERS
#############################################
print_usage() {
    cat << 'EOF'
Kuruka RVR L2 Bridge Tool v2.1

Usage: l2bridge <command> [options]

Commands:
  setup <ip> <name>       Full setup/reconfigure both GCS and Aircraft
  add <ip> [name]         Connect to an already-setup aircraft (no reinstall)
  start <aircraft_ip>     Start services on both sides
  stop [aircraft_ip]      Stop services on both sides
  restart <aircraft_ip>   Restart services on both sides
  status                  Show local bridge status
  remote <aircraft_ip>    Show remote aircraft status via SSH
  logs [lines]            Show recent logs (default: 20 lines)
  debug <aircraft_ip>     Run full diagnostics on both sides
  config                  Show current configuration
  uninstall [aircraft_ip] Remove all configuration from both sides
  
  monitor [--daemon]      Health check and auto-repair
  watchdog-install        Install cron-based watchdog for auto-recovery
  watchdog-remove         Remove watchdog cron job

  webui-install           Install web-based control panel on port 8081
  webui-remove            Remove web UI

EOF
}

log_msg() {
    local level="$1"
    local msg="$2"
    local timestamp=$(date '+%Y-%m-%d %H:%M:%S')
    echo "[$timestamp] [$level] $msg"
    logger -t l2bridge -p "daemon.$level" "$msg" 2>/dev/null || true
}

log_info() { log_msg "info" "$1"; }
log_warn() { log_msg "warn" "$1"; }
log_error() { log_msg "err" "$1"; }

get_tailscale_ip_nowait() {
    tailscale ip -4 2>/dev/null | head -1
}

get_local_tailscale_ip() {
    local ip=$(get_tailscale_ip_nowait)
    if [ -z "$ip" ]; then
        echo "ERROR: Could not get Tailscale IP. Is Tailscale running?" >&2
        exit 1
    fi
    echo "$ip"
}

wait_for_tailscale() {
    local timeout="${1:-$TAILSCALE_WAIT_TIMEOUT}"
    local elapsed=0
    
    log_info "Waiting for Tailscale (timeout: ${timeout}s)..."
    
    while [ $elapsed -lt $timeout ]; do
        if tailscale status >/dev/null 2>&1; then
            local ip=$(get_tailscale_ip_nowait)
            if [ -n "$ip" ]; then
                log_info "Tailscale ready with IP: $ip"
                return 0
            fi
        fi
        sleep $TAILSCALE_CHECK_INTERVAL
        elapsed=$((elapsed + TAILSCALE_CHECK_INTERVAL))
    done
    
    log_error "Tailscale not ready after ${timeout}s"
    return 1
}

is_tailscale_ready() {
    tailscale status >/dev/null 2>&1 && [ -n "$(get_tailscale_ip_nowait)" ]
}

get_aircraft_ip() {
    if [ -n "$1" ]; then
        echo "$1"
    elif [ -f "$STATE_FILE" ]; then
        . "$STATE_FILE"
        echo "${AIRCRAFT_IP:-}"
    fi
}

require_aircraft_ip() {
    local ip=$(get_aircraft_ip "$1")
    if [ -z "$ip" ]; then
        echo "ERROR: Aircraft IP required."
        exit 1
    fi
    echo "$ip"
}

save_aircraft_ip() {
    echo "AIRCRAFT_IP=\"$1\"" > "$STATE_FILE"
}

# Save or update aircraft profile in aircraft.json and set as active
# Usage: save_aircraft_profile <name> <ip>
save_aircraft_profile() {
    local name="$1"
    local ip="$2"
    local aircraft_file="/etc/l2bridge/aircraft.json"

    mkdir -p /etc/l2bridge

    # Generate profile ID from name (lowercase, replace spaces/special chars with dash)
    local id=$(echo "$name" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9_-]/-/g; s/--*/-/g; s/^-//; s/-$//')
    [ -z "$id" ] && id="aircraft-$(echo "$ip" | tr '.' '-')"

    local created=$(date -Iseconds 2>/dev/null || date '+%Y-%m-%dT%H:%M:%S')

    # Initialize file if it doesn't exist
    if [ ! -f "$aircraft_file" ]; then
        printf '{\n  "version": 1,\n  "active": "",\n  "profiles": {}\n}\n' > "$aircraft_file"
    fi

    # Extract existing profiles
    local tmp_profiles=$(mktemp)
    awk '
    /"[a-zA-Z0-9_-]+":[[:space:]]*\{/ {
        pid = $0
        sub(/^[^"]*"/, "", pid)
        sub(/".*/, "", pid)
        if (pid != "profiles") {
            current_id = pid
            p_pass[current_id] = ""
        }
    }
    current_id && /"name":/ {
        val = $0; sub(/.*"name":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_name[current_id] = val
    }
    current_id && /"tailscale_ip":/ {
        val = $0; sub(/.*"tailscale_ip":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_ip[current_id] = val
    }
    current_id && /"ssh_password":/ {
        val = $0; sub(/.*"ssh_password":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_pass[current_id] = val
    }
    current_id && /"created":/ {
        val = $0; sub(/.*"created":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_created[current_id] = val
    }
    current_id && /"last_used":/ {
        val = $0; sub(/.*"last_used":[[:space:]]*"/, "", val); sub(/".*/, "", val)
        p_last[current_id] = val
        print current_id "|" p_name[current_id] "|" p_ip[current_id] "|" p_pass[current_id] "|" p_created[current_id] "|" p_last[current_id]
    }
    ' "$aircraft_file" > "$tmp_profiles"

    # Check if profile with this ID or IP already exists
    local found=0
    local tmp_updated=$(mktemp)
    while IFS='|' read -r pid pname pip ppass pcreated plast; do
        [ -z "$pid" ] && continue
        if [ "$pid" = "$id" ] || [ "$pip" = "$ip" ]; then
            # Update existing profile - keep password and created time
            echo "$id|$name|$ip|$ppass|$pcreated|$created"
            found=1
        else
            echo "$pid|$pname|$pip|$ppass|$pcreated|$plast"
        fi
    done < "$tmp_profiles" > "$tmp_updated"

    # Add new profile if not found
    if [ "$found" = "0" ]; then
        echo "$id|$name|$ip||$created|$created" >> "$tmp_updated"
    fi

    # Rebuild JSON file
    printf '{\n  "version": 1,\n  "active": "%s",\n  "profiles": {\n' "$id" > "$aircraft_file"

    local first=1
    while IFS='|' read -r pid pname pip ppass pcreated plast; do
        [ -z "$pid" ] && continue
        [ $first -eq 0 ] && printf ',\n' >> "$aircraft_file"
        printf '    "%s": {\n' "$pid" >> "$aircraft_file"
        printf '      "name": "%s",\n' "$pname" >> "$aircraft_file"
        printf '      "tailscale_ip": "%s",\n' "$pip" >> "$aircraft_file"
        printf '      "ssh_password": "%s",\n' "$ppass" >> "$aircraft_file"
        printf '      "created": "%s",\n' "$pcreated" >> "$aircraft_file"
        printf '      "last_used": "%s"\n' "$plast" >> "$aircraft_file"
        printf '    }' >> "$aircraft_file"
        first=0
    done < "$tmp_updated"

    printf '\n  }\n}\n' >> "$aircraft_file"
    rm -f "$tmp_profiles" "$tmp_updated"

    echo "[*] Aircraft profile '$name' ($id) saved and set active."
}

check_aircraft_reachable() {
    ping -c 1 -W 5 "$1" > /dev/null 2>&1
}

ensure_ssh_key() {
    if [ ! -f "$SSH_KEY" ]; then
        echo "[*] Generating SSH key..."
        mkdir -p /root/.ssh
        chmod 700 /root/.ssh
        dropbearkey -t ed25519 -f "$SSH_KEY" >/dev/null 2>&1
        dropbearkey -y -f "$SSH_KEY" 2>/dev/null | grep "^ssh-" > "$SSH_PUBKEY"
    fi
}

ssh_key_works() {
    local ip="$1"
    [ -f "$SSH_KEY" ] || return 1
    # Background dbclient with key-only auth
    # If key works: completes quickly, returns 0
    # If key fails: dbclient prompts on /dev/tty, blocks, gets killed after timeout
    dbclient -i "$SSH_KEY" -y root@"$ip" "exit" </dev/null >/dev/null 2>&1 &
    local pid=$!
    # 10s timeout for satellite latency on SSH handshake
    local i=0
    while [ $i -lt 10 ]; do
        kill -0 $pid 2>/dev/null || { wait $pid; return $?; }
        sleep 1
        i=$((i + 1))
    done
    kill $pid 2>/dev/null; wait $pid 2>/dev/null
    return 1
}

setup_ssh_keys() {
    local ip="$1"
    local password="$2"
    ensure_ssh_key
    if ssh_key_works "$ip"; then
        echo "[*] SSH key auth already configured for $ip"
        return 0
    fi

    local pubkey=$(cat "$SSH_PUBKEY")
    local ssh_cmd="mkdir -p /etc/dropbear && echo '$pubkey' >> /etc/dropbear/authorized_keys && chmod 600 /etc/dropbear/authorized_keys && sort -u /etc/dropbear/authorized_keys -o /etc/dropbear/authorized_keys"

    if [ -n "$password" ]; then
        # Non-interactive: use sshpass if available
        echo "[*] Installing SSH key on $ip (using stored password)..."
        if command -v sshpass >/dev/null 2>&1; then
            sshpass -p "$password" dbclient -y root@"$ip" "$ssh_cmd" 2>/dev/null
        else
            # Fallback: install sshpass first
            echo "    Installing sshpass..."
            opkg update >/dev/null 2>&1
            opkg install sshpass >/dev/null 2>&1
            if command -v sshpass >/dev/null 2>&1; then
                sshpass -p "$password" dbclient -y root@"$ip" "$ssh_cmd" 2>/dev/null
            else
                echo "    ERROR: sshpass not available. Please install SSH key manually."
                return 1
            fi
        fi
    else
        # Interactive: prompt for password
        echo "[*] Installing SSH key on $ip (enter password once)..."
        dbclient -y root@"$ip" "$ssh_cmd"
    fi

    sleep 1
    if ssh_key_works "$ip"; then
        echo "    SSH key installed successfully."
    else
        echo "    ERROR: Key auth failed."
        return 1
    fi
}

ssh_aircraft() {
    local ip="$1"; shift
    dbclient -i "$SSH_KEY" -y root@"$ip" "$@"
}

#############################################
# HEALTH CHECK FUNCTIONS
#############################################
check_local_health() {
    local issues=""
    is_tailscale_ready || issues="${issues}tailscale_down,"
    pgrep -f kcptun-server > /dev/null 2>&1 || issues="${issues}kcptun_down,"
    pgrep tincd > /dev/null 2>&1 || issues="${issues}tincd_down,"
    ip link show l2bridge > /dev/null 2>&1 || issues="${issues}interface_missing,"
    
    if pgrep tincd > /dev/null 2>&1; then
        local nodes=$(tinc -n l2bridge dump nodes 2>/dev/null | wc -l)
        [ "$nodes" -lt 2 ] && issues="${issues}tinc_no_peers,"
    fi
    
    [ -n "$issues" ] && { echo "${issues%,}"; return 1; }
    return 0
}

record_health() {
    cat > "$HEALTH_FILE" << EOF
LAST_CHECK="$(date '+%Y-%m-%d %H:%M:%S')"
STATUS="$1"
DETAILS="$2"
EOF
}

#############################################
# SERVICE MANAGEMENT
#############################################
start_local_services() {
    log_info "Starting local services..."
    
    if ! wait_for_tailscale; then
        log_error "Cannot start - Tailscale not available"
        return 1
    fi
    
    local GCS_IP=$(get_local_tailscale_ip)
    
    # Update kcptun config with current IP
    if [ -f /etc/kcptun/server.json ]; then
        sed -i "s|\"listen\": \"[^\"]*:|\"listen\": \"$GCS_IP:|g" /etc/kcptun/server.json
    fi
    
    /etc/init.d/kcptun-server start 2>/dev/null || true
    sleep $KCPTUN_SETTLE_TIME
    
    if ! pgrep -f kcptun-server > /dev/null 2>&1; then
        log_error "kcptun-server failed to start"
        return 1
    fi
    
    /etc/init.d/tinc-l2bridge start 2>/dev/null || true
    sleep 2
    
    log_info "Local services started"
    return 0
}

start_aircraft_services() {
    local AIRCRAFT_IP="$1"
    local GCS_IP=$(get_local_tailscale_ip)
    
    log_info "Starting aircraft services on $AIRCRAFT_IP..."
    
    check_aircraft_reachable "$AIRCRAFT_IP" || { log_warn "Aircraft unreachable"; return 1; }
    
    ssh_aircraft "$AIRCRAFT_IP" "
        [ -f /etc/kcptun/client.json ] && sed -i 's|\"remoteaddr\": \"[^\"]*:|\"remoteaddr\": \"$GCS_IP:|g' /etc/kcptun/client.json
        /etc/init.d/kcptun-client start 2>/dev/null || true
        sleep 3
        /etc/init.d/tinc-l2bridge start 2>/dev/null || true
    " 2>/dev/null || { log_warn "Could not start aircraft services"; return 1; }
    
    log_info "Aircraft services started"
}

stop_local_services() {
    log_info "Stopping local services..."
    /etc/init.d/tinc-l2bridge stop 2>/dev/null || true
    /etc/init.d/kcptun-server stop 2>/dev/null || true
    ip link set l2bridge nomaster 2>/dev/null || true
    ip link del l2bridge 2>/dev/null || true
    iptables -D OUTPUT -o br-lan -p udp --dport 41641 -j DROP 2>/dev/null || true
    iptables -D OUTPUT -o br-lan -p udp --sport 41641 -j DROP 2>/dev/null || true
    iptables -D FORWARD -i l2bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
    iptables -D FORWARD -o l2bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
    iptables -D FORWARD -i l2bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
    iptables -D FORWARD -o l2bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
}

stop_aircraft_services() {
    local AIRCRAFT_IP="$1"
    log_info "Stopping aircraft services..."
    check_aircraft_reachable "$AIRCRAFT_IP" && ssh_key_works "$AIRCRAFT_IP" && ssh_aircraft "$AIRCRAFT_IP" '
        /etc/init.d/tinc-l2bridge stop 2>/dev/null || true
        /etc/init.d/kcptun-client stop 2>/dev/null || true
        ip link set l2bridge nomaster 2>/dev/null || true
        ip link del l2bridge 2>/dev/null || true
        iptables -D OUTPUT -o br-lan -p udp --dport 41641 -j DROP 2>/dev/null || true
        iptables -D OUTPUT -o br-lan -p udp --sport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -i l2bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -o l2bridge -p udp --dport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -i l2bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
        iptables -D FORWARD -o l2bridge -p udp --sport 41641 -j DROP 2>/dev/null || true
    ' 2>/dev/null || true
}

#############################################
# MONITOR COMMAND
#############################################
cmd_monitor() {
    local daemon_mode=0
    [ "$1" = "--daemon" ] || [ "$1" = "-d" ] && daemon_mode=1
    local AIRCRAFT_IP=$(get_aircraft_ip)
    
    if [ $daemon_mode -eq 1 ]; then
        log_info "Starting monitor daemon"
        while true; do
            do_health_check "$AIRCRAFT_IP"
            sleep $HEALTH_CHECK_INTERVAL
        done
    else
        do_health_check "$AIRCRAFT_IP"
    fi
}

do_health_check() {
    local AIRCRAFT_IP="$1"
    local restart_needed=0
    local issues
    
    issues=$(check_local_health)
    local local_status=$?
    
    if [ $local_status -ne 0 ]; then
        log_warn "Health issues: $issues"
        
        case "$issues" in
            *tailscale_down*)
                log_warn "Tailscale down, waiting..."
                if wait_for_tailscale 60; then
                    restart_needed=1
                else
                    record_health "ERROR" "tailscale_down"
                    return 1
                fi
                ;;
            *kcptun_down*|*tincd_down*|*interface_missing*)
                restart_needed=1
                ;;
            *tinc_no_peers*)
                if [ -n "$AIRCRAFT_IP" ] && check_aircraft_reachable "$AIRCRAFT_IP"; then
                    restart_needed=2
                fi
                ;;
        esac
    fi
    
    if [ $restart_needed -eq 1 ]; then
        log_info "Restarting local services..."
        stop_local_services
        sleep $SERVICE_RESTART_DELAY
        start_local_services
        record_health "RECOVERING" "restarted_local"
    elif [ $restart_needed -eq 2 ]; then
        log_info "Restarting both sides..."
        stop_local_services
        [ -n "$AIRCRAFT_IP" ] && stop_aircraft_services "$AIRCRAFT_IP"
        sleep $SERVICE_RESTART_DELAY
        start_local_services
        [ -n "$AIRCRAFT_IP" ] && start_aircraft_services "$AIRCRAFT_IP"
        record_health "RECOVERING" "restarted_both"
    fi
    
    sleep 5
    issues=$(check_local_health)
    if [ $? -eq 0 ]; then
        log_info "Health check: OK"
        record_health "OK" ""
        return 0
    else
        log_error "Health check: FAILED ($issues)"
        record_health "ERROR" "$issues"
        return 1
    fi
}

#############################################
# WATCHDOG INSTALL/REMOVE
#############################################
cmd_watchdog_install() {
    log_info "Installing watchdog..."
    
    cat > /etc/l2bridge-watchdog.sh << 'WATCHDOG'
#!/bin/sh
LOCK="/tmp/l2bridge-watchdog.lock"
LOG="/tmp/l2bridge-watchdog.log"

[ -f "$LOCK" ] && kill -0 $(cat "$LOCK") 2>/dev/null && exit 0
echo $$ > "$LOCK"
trap "rm -f $LOCK" EXIT

# Always run health check (updates /tmp/l2bridge.health and repairs if needed)
/usr/bin/l2bridge monitor >> "$LOG" 2>&1

[ -f "$LOG" ] && tail -100 "$LOG" > "$LOG.tmp" && mv "$LOG.tmp" "$LOG"
WATCHDOG
    chmod +x /etc/l2bridge-watchdog.sh
    
    if ! crontab -l 2>/dev/null | grep -q "l2bridge-watchdog"; then
        (crontab -l 2>/dev/null; echo "* * * * * /etc/l2bridge-watchdog.sh") | crontab -
    fi
    
    # Boot-time startup
    if [ -f /etc/rc.local ] && ! grep -q "l2bridge" /etc/rc.local; then
        sed -i '/^exit 0/d' /etc/rc.local
        cat >> /etc/rc.local << 'RCLOCAL'

# L2Bridge auto-start
( sleep 30; /usr/bin/l2bridge monitor ) &
exit 0
RCLOCAL
    fi
    
    echo "Watchdog installed. View log: cat /tmp/l2bridge-watchdog.log"
}

cmd_watchdog_remove() {
    crontab -l 2>/dev/null | grep -v "l2bridge-watchdog" | crontab - 2>/dev/null || true
    rm -f /etc/l2bridge-watchdog.sh
    [ -f /etc/rc.local ] && sed -i '/L2Bridge auto-start/,/^exit 0/d' /etc/rc.local
    log_info "Watchdog removed"
}

#############################################
# SETUP COMMAND
#############################################
cmd_setup() {
    local AIRCRAFT_IP="$1"
    local AIRCRAFT_NAME="$2"

    [ -z "$AIRCRAFT_IP" ] && { echo "ERROR: Usage: l2bridge setup <aircraft_ip> <aircraft_name>"; exit 1; }
    [ -z "$AIRCRAFT_NAME" ] && { echo "ERROR: Aircraft name required. Usage: l2bridge setup <aircraft_ip> <aircraft_name>"; exit 1; }

    local GCS_IP=$(get_local_tailscale_ip)

    # Initialize setup log
    init_setup_log

    echo "========================================="
    echo "  Kuruka RVR L2 Bridge Setup v2.2"
    echo "========================================="
    echo "  GCS:      $GCS_IP"
    echo "  Aircraft: $AIRCRAFT_IP ($AIRCRAFT_NAME)"
    echo "========================================="
    echo ""

    # Pre-flight checks
    echo "[*] Pre-flight checks..."
    log_cmd "GCS bridge interfaces" ip link show type bridge
    log_cmd "GCS br-lan info" ip link show br-lan
    log_cmd "GCS bridge ports" bridge link show
    echo ""

    echo "[*] Testing connectivity..."
    check_aircraft_reachable "$AIRCRAFT_IP" || { echo "ERROR: Cannot reach aircraft"; exit 1; }
    echo "    Aircraft reachable."

    # Get password from aircraft profile if available (for non-interactive setup)
    local aircraft_password=""
    if [ -f "/etc/l2bridge/aircraft.json" ]; then
        # Try to get password for this IP from profiles
        # Parse JSON: find profile with matching IP and extract its password
        aircraft_password=$(awk -v ip="$AIRCRAFT_IP" '
            BEGIN { in_profile=0; current_ip=""; current_pass="" }
            /"[a-zA-Z0-9_-]+":[[:space:]]*\{/ { in_profile=1; current_ip=""; current_pass="" }
            in_profile && /"tailscale_ip":/ {
                gsub(/.*"tailscale_ip":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_ip = $0
            }
            in_profile && /"ssh_password":/ {
                gsub(/.*"ssh_password":[[:space:]]*"/, ""); gsub(/".*/, "")
                current_pass = $0
            }
            /\}/ {
                if (in_profile && current_ip == ip && current_pass != "") {
                    print current_pass
                    exit
                }
                in_profile = 0
            }
        ' /etc/l2bridge/aircraft.json 2>/dev/null)
    fi

    # Setup SSH keys first (before any SSH operations)
    setup_ssh_keys "$AIRCRAFT_IP" "$aircraft_password" || exit 1

    # Now check aircraft bridge with SSH
    echo "[*] Checking aircraft bridge configuration..."
    ssh_aircraft "$AIRCRAFT_IP" "ip link show type bridge; bridge link show" 2>/dev/null || echo "    (Could not query aircraft)"
    echo ""

    # Aircraft pre-flight checks
    echo "[*] Aircraft pre-flight checks..."
    log_cmd "Aircraft bridges" ssh_aircraft "$AIRCRAFT_IP" "ip link show type bridge"
    log_cmd "Aircraft br-lan" ssh_aircraft "$AIRCRAFT_IP" "ip link show br-lan 2>/dev/null || ip link show | grep -E 'br-|bridge'"
    
    # Detect aircraft bridge name (might not be br-lan on all devices)
    local aircraft_bridge=$(ssh_aircraft "$AIRCRAFT_IP" "ip link show type bridge | grep -oE '^[0-9]+: [^:]+' | head -1 | awk '{print \$2}'")
    aircraft_bridge="${aircraft_bridge:-br-lan}"
    echo "    Aircraft bridge detected: $aircraft_bridge"
    
    # Detect GCS bridge name
    local gcs_bridge=$(ip link show type bridge | grep -oE '^[0-9]+: [^:]+' | head -1 | awk '{print $2}')
    gcs_bridge="${gcs_bridge:-br-lan}"
    echo "    GCS bridge detected: $gcs_bridge"

    echo "[*] Stopping existing services..."
    cmd_stop_internal "$AIRCRAFT_IP" 2>/dev/null || true

    # GCS SETUP
    echo "[GCS] Installing packages..."
    opkg update >/dev/null 2>&1 || true
    opkg install tinc kcptun-server >/dev/null 2>&1 || true

    echo "[GCS] Initializing tinc..."
    rm -rf /etc/tinc/$NETWORK_NAME
    mkdir -p /etc/tinc/$NETWORK_NAME/hosts /etc/kcptun
    tinc -n $NETWORK_NAME init ground

    cat > /etc/tinc/$NETWORK_NAME/tinc.conf << EOF
Name = ground
Mode = switch
