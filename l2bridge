#############################################
# MONITOR COMMAND
#############################################
cmd_monitor() {
    local daemon_mode=0
    [ "$1" = "--daemon" ] || [ "$1" = "-d" ] && daemon_mode=1
    local AIRCRAFT_IP=$(get_aircraft_ip)
    
    if [ $daemon_mode -eq 1 ]; then
        log_info "Starting monitor daemon"
        while true; do
            do_health_check "$AIRCRAFT_IP"
            sleep $HEALTH_CHECK_INTERVAL
        done
    else
        do_health_check "$AIRCRAFT_IP"
    fi
}

do_health_check() {
    local AIRCRAFT_IP="$1"
    local restart_needed=0
    local issues
    
    issues=$(check_local_health)
    local local_status=$?
    
    if [ $local_status -ne 0 ]; then
        log_warn "Health issues: $issues"
        
        case "$issues" in
            *tailscale_down*)
                log_warn "Tailscale down, waiting..."
                if wait_for_tailscale 60; then
                    restart_needed=1
                else
                    record_health "ERROR" "tailscale_down"
                    return 1
                fi
                ;;
            *kcptun_down*|*tincd_down*|*interface_missing*)
                restart_needed=1
                ;;
            *tinc_no_peers*)
                if [ -n "$AIRCRAFT_IP" ] && check_aircraft_reachable "$AIRCRAFT_IP"; then
                    restart_needed=2
                fi
                ;;
        esac
    fi
    
    if [ $restart_needed -eq 1 ]; then
        log_info "Restarting local services..."
        stop_local_services
        sleep $SERVICE_RESTART_DELAY
        start_local_services
        record_health "RECOVERING" "restarted_local"
    elif [ $restart_needed -eq 2 ]; then
        log_info "Restarting both sides..."
        stop_local_services
        [ -n "$AIRCRAFT_IP" ] && stop_aircraft_services "$AIRCRAFT_IP"
        sleep $SERVICE_RESTART_DELAY
        start_local_services
        [ -n "$AIRCRAFT_IP" ] && start_aircraft_services "$AIRCRAFT_IP"
        record_health "RECOVERING" "restarted_both"
    fi
    
    sleep 5
    issues=$(check_local_health)
    if [ $? -eq 0 ]; then
        log_info "Health check: OK"
        record_health "OK" ""
        return 0
    else
        log_error "Health check: FAILED ($issues)"
        record_health "ERROR" "$issues"
        return 1
    fi
}

#############################################
# WATCHDOG INSTALL/REMOVE
#############################################
cmd_watchdog_install() {
    log_info "Installing watchdog..."
    
    cat > /etc/l2bridge-watchdog.sh << 'WATCHDOG'
#!/bin/sh
LOCK="/tmp/l2bridge-watchdog.lock"
LOG="/tmp/l2bridge-watchdog.log"

[ -f "$LOCK" ] && kill -0 $(cat "$LOCK") 2>/dev/null && exit 0
echo $$ > "$LOCK"
trap "rm -f $LOCK" EXIT

# Always run health check (updates /tmp/l2bridge.health and repairs if needed)
/usr/bin/l2bridge monitor >> "$LOG" 2>&1

[ -f "$LOG" ] && tail -100 "$LOG" > "$LOG.tmp" && mv "$LOG.tmp" "$LOG"
WATCHDOG
    chmod +x /etc/l2bridge-watchdog.sh
    
    if ! crontab -l 2>/dev/null | grep -q "l2bridge-watchdog"; then
        (crontab -l 2>/dev/null; echo "* * * * * /etc/l2bridge-watchdog.sh") | crontab -
    fi
    
    # Boot-time startup
    if [ -f /etc/rc.local ] && ! grep -q "l2bridge" /etc/rc.local; then
        sed -i '/^exit 0/d' /etc/rc.local
        cat >> /etc/rc.local << 'RCLOCAL'

# L2Bridge auto-start
( sleep 30; /usr/bin/l2bridge monitor ) &
exit 0
RCLOCAL
    fi
    
    echo "Watchdog installed. View log: cat /tmp/l2bridge-watchdog.log"
}

cmd_watchdog_remove() {
    crontab -l 2>/dev/null | grep -v "l2bridge-watchdog" | crontab - 2>/dev/null || true
    rm -f /etc/l2bridge-watchdog.sh
    [ -f /etc/rc.local ] && sed -i '/L2Bridge auto-start/,/^exit 0/d' /etc/rc.local
    log_info "Watchdog removed"
}

